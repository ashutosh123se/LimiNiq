// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  email         String
  phone         String?
  company       String?
  website       String?
  services      String[]
  budget        String?
  timeline      String?
  source        String?
  message       String?
  attachmentUrl String?
  status        LeadStatus @default(NEW)
  priority      Priority   @default(MEDIUM)
  assignedTo    String?
  notes         String?
  followUpDate  DateTime?
  score         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  ipAddress     String?
  userAgent     String?
  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?
  pageUrl       String?

  emailsSent Email[]
  activities Activity[]
  aiChatSessions AIChatSession[]
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  CONVERTED
  LOST
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Email {
  id      String    @id @default(cuid())
  leadId  String
  lead    Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject String
  body    String    @db.Text
  type    EmailType
  sentAt  DateTime  @default(now())
  status  String    @default("sent")
}

enum EmailType {
  AUTO_REPLY
  ADMIN_NOTIFICATION
  FOLLOW_UP
  PROPOSAL
  CUSTOM
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  note      String
  createdAt DateTime @default(now())
  createdBy String?
}

model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  excerpt     String
  content     String       @db.Text
  category    String
  coverImage  String?
  author      String
  published   Boolean      @default(false)
  publishedAt DateTime?
  views       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tags        String[]
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  postType    BlogPostType @default(ARTICLE)
  trending    Boolean      @default(false)
  pollOptions Json?
  pollEndsAt  DateTime?
  pollVotes   PollVote[]
}

enum BlogPostType {
  ARTICLE
  POLL
}

model TrendingTopic {
  id          String   @id @default(cuid())
  label       String
  slug        String   @unique
  description String?
  emoji       String?
  color       String   @default("#3B5BFF")
  href        String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PollVote {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  optionId  String
  voterKey  String
  createdAt DateTime @default(now())

  @@unique([postId, voterKey])
}

model PageView {
  id    String   @id @default(cuid())
  page  String
  views Int      @default(0)
  date  DateTime @default(now())

  @@unique([page, date])
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(EDITOR)
  createdAt DateTime  @default(now())

  resetToken       String?
  resetTokenExpiry DateTime?
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model SiteSettings {
  id            String @id @default("1")
  companyEmail  String @default("hello@liminiq.com")
  companyPhone  String @default("+91 XXXXX XXXXX")
  companyCity   String @default("India")
  socialLinks   Json   @default("{}")
  seoDefaults   Json   @default("{}")
  emailSettings Json   @default("{}")
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String
  role      String
  quote     String
  rating    Float    @default(5)
  avatar    String?
  service   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  client      String
  category    String
  description String
  metrics     Json
  coverImage  String?
  liveUrl     String?
  tags        String[]
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  subscribed Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model NewsletterCampaign {
  id        String    @id @default(cuid())
  subject   String
  body      String    @db.Text
  sentCount Int       @default(0)
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model StartingPrice {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  shortLabel    String
  startingPrice String
  priceNote     String
  summary       String
  highlights    String[]
  color         String
  iconKey       String   @default("Code2")
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model PricingPlan {
  id          String   @id @default(cuid())
  type        PlanType
  name        String
  price       String
  priceSuffix String
  tagline     String
  features    Json     // Array of { text: string, included: boolean }
  ctaText     String
  badge       String?
  delivery    String?
  elevated    Boolean  @default(false)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

enum PlanType {
  WEB_DEV
  SEO_MARKETING
}

model AIChatSession {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  messages     Json
  visitorName  String?
  visitorPhone String?
  visitorEmail String?
  summary      String?
  messageCount Int      @default(0)
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
